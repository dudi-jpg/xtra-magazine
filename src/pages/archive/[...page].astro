---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import ArticleCard from '../../components/ArticleCard.astro';
import Pagination from '../../components/Pagination.astro';
import { PAGE_SIZE } from '../../consts';

export async function getStaticPaths({ paginate }) {
  const items = (await getCollection('articles')).sort(
    (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
  );
  return paginate(items, { pageSize: PAGE_SIZE });
}

const { page } = Astro.props;
---

<BaseLayout title="כל הכתבות" description="ארכיון הכתבות של xtra — מגזין התרבות והפנאי של ישראל">
  <section class="container section">
    <header class="arch-head">
      <span class="kicker">ארכיון</span>
      <h1>כל הכתבות</h1>
      <p class="muted">{page.total} כתבות במגזין · עמוד {page.currentPage} מתוך {page.lastPage}</p>
    </header>

    <div class="grid">
      {page.data.map((a) => <ArticleCard article={a} />)}
    </div>

    <Pagination page={page} base="/archive/" />
  </section>
</BaseLayout>

<style>
  .arch-head {
    margin-bottom: 30px;
    padding-bottom: 18px;
    border-bottom: 3px solid var(--ink);
  }
  .kicker {
    color: var(--accent);
    font-weight: 800;
    font-size: 0.8rem;
    letter-spacing: 0.12em;
  }
  .arch-head h1 {
    font-size: clamp(1.9rem, 4vw, 2.8rem);
    margin: 6px 0 4px;
  }
  .grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 22px;
  }
  @media (max-width: 980px) {
    .grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  @media (max-width: 620px) {
    .grid {
      grid-template-columns: 1fr;
    }
  }
</style>
