---
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';
import BaseLayout from '../layouts/BaseLayout.astro';
import ArticleCard from '../components/ArticleCard.astro';
import FormattedDate from '../components/FormattedDate.astro';
import { CATEGORIES, catColor } from '../consts';

const all = (await getCollection('articles')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

// 5 הכתבות האחרונות שהתפרסמו — לסליידר כתבת השער ולרשימת ההירו (דינמי)
const latest = all.slice(0, 5);
const picks = all.slice(0, 6); // רשימת "חם עכשיו" לסיידבר

// המשפט הראשון מתחילת גוף הכתבה (לתצוגה בהירו)
function firstSentence(body: string | undefined): string {
  const line = (body || '')
    .replace(/!\[[^\]]*\]\([^)]*\)/g, '') // תמונות
    .replace(/\[([^\]]+)\]\([^)]*\)/g, '$1') // קישורים → טקסט
    .split('\n')
    .map((l) => l.trim())
    .find((l) => l && !l.startsWith('#') && !l.startsWith('|') && !l.startsWith('>')) || '';
  const clean = line.replace(/[*_`]/g, '').trim();
  const m = clean.match(/^[\s\S]*?[.!?](?:\s|$)/);
  let s = (m ? m[0] : clean).trim();
  if (s.length > 170) s = s.slice(0, 167).trim() + '…';
  return s;
}

// בלוק לכל קטגוריה — 4 הכתבות האחרונות בקטגוריה
const blocks = CATEGORIES.map((category) => ({
  category,
  items: all.filter((a) => a.data.category === category).slice(0, 4),
})).filter((b) => b.items.length > 0);

const catHref = (c: string) => `/category/${encodeURIComponent(c)}/`;
---

<BaseLayout>
  <!-- ===== HERO: auto-rotating cover slider + headline list (5 latest) ===== -->
  {
    latest.length > 0 && (
      <section class="container hero">
        <div class="slider" data-slider aria-label="כתבות מובילות">
          {latest.map((a, i) => (
            <article class={`slide${i === 0 ? ' active' : ''}`} data-slide={i} style={`--cat:${catColor(a.data.category)}`}>
              <a href={`/articles/${a.id}/`} class="lead-media">
                {a.data.cover && (
                  <Image src={a.data.cover} alt={a.data.coverAlt} widths={[700, 1100, 1500]} sizes="(max-width: 900px) 100vw, 780px" />
                )}
              </a>
              <a href={catHref(a.data.category)} class="lead-cat">{a.data.category}</a>
              <h1><a href={`/articles/${a.id}/`}>{a.data.title}</a></h1>
              <p class="lead-dek">{a.data.description}</p>
              <div class="lead-meta">
                <span>מאת {a.data.author}</span>
                <span class="sep" />
                <FormattedDate date={a.data.pubDate} />
              </div>
            </article>
          ))}
          <div class="slider-dots" role="tablist">
            {latest.map((_, i) => (
              <button class={`dot${i === 0 ? ' active' : ''}`} data-dot={i} aria-label={`כתבה ${i + 1}`} />
            ))}
          </div>
        </div>

        <aside class="hlist">
          {latest.map((a, i) => (
            <a href={`/articles/${a.id}/`} class={`hitem${i === 0 ? ' active' : ''}`} data-hitem={i} style={`--cat:${catColor(a.data.category)}`}>
              {a.data.cover && (
                <span class="hitem-media">
                  <Image src={a.data.cover} alt={a.data.coverAlt} widths={[120, 240]} sizes="120px" />
                </span>
              )}
              <span class="hitem-body">
                <span class="hitem-cat">{a.data.category}</span>
                <h3>{a.data.title}</h3>
                <span class="hitem-excerpt">{firstSentence(a.body)}</span>
                <span class="hitem-more">המשך קריאה ←</span>
              </span>
            </a>
          ))}
        </aside>
      </section>
    )
  }

  <!-- ===== Main + Sidebar ===== -->
  <div class="container layout">
    <main class="feed">
      {
        blocks.map((block) => (
          <section class="catblock" style={`--cat:${catColor(block.category)}`}>
            <div class="blockhead">
              <h2>{block.category}</h2>
              <a class="blockmore" href={catHref(block.category)}>לכל הכתבות ←</a>
            </div>
            <div class="cards2">
              {block.items.map((a) => (
                <ArticleCard article={a} />
              ))}
            </div>
          </section>
        ))
      }
    </main>

    <aside class="sidebar">
      <div class="side-card">
        <h3 class="side-h">חם עכשיו</h3>
        <ol class="picks">
          {picks.map((a) => (
            <li style={`--cat:${catColor(a.data.category)}`}>
              <a href={`/articles/${a.id}/`}>
                <span class="picks-cat">{a.data.category}</span>
                <span class="picks-title">{a.data.title}</span>
              </a>
            </li>
          ))}
        </ol>
      </div>

      <div class="side-card">
        <h3 class="side-h">מדורים</h3>
        <div class="sections">
          {CATEGORIES.map((c) => (
            <a href={catHref(c)} class="sec-chip" style={`--cat:${catColor(c)}`}>{c}</a>
          ))}
        </div>
      </div>

      <div class="side-card newsletter">
        <h3>הניוזלטר של xtra</h3>
        <p>מה שווה לראות, לשמוע ולקרוא השבוע — ביקורות, המלצות והופעות, ישירות למייל.</p>
        <form action="mailto:info@xtra.co.il" method="post" class="nl-form">
          <input type="email" placeholder="כתובת אימייל" aria-label="אימייל" required />
          <button type="submit">הרשמה</button>
        </form>
      </div>
    </aside>
  </div>
</BaseLayout>

<style>
  /* ===== HERO ===== */
  .hero {
    display: grid;
    grid-template-columns: 1.62fr 1fr;
    gap: 40px;
    padding-top: 34px;
    padding-bottom: 40px;
    border-bottom: 1px solid var(--line);
    align-items: start;
  }

  /* ===== Cover slider (auto-rotating) ===== */
  .slider {
    position: relative;
  }
  .slide {
    position: absolute;
    inset: 0;
    opacity: 0;
    visibility: hidden;
    transition: opacity 0.6s ease;
    pointer-events: none;
  }
  .slide.active {
    position: relative;
    opacity: 1;
    visibility: visible;
    pointer-events: auto;
  }
  .lead-media {
    display: block;
    aspect-ratio: 16 / 9;
    overflow: hidden;
    border-radius: var(--radius);
    background: var(--surface-2);
    margin-bottom: 18px;
  }
  .lead-media :global(img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s ease;
  }
  .slide:hover .lead-media :global(img) {
    transform: scale(1.03);
  }
  .lead-cat,
  .hitem-cat {
    display: inline-block;
    font-weight: 800;
    font-size: 0.78rem;
    letter-spacing: 0.04em;
    color: var(--cat);
    margin-bottom: 10px;
  }
  .slide h1 {
    font-size: clamp(1.7rem, 3.2vw, 2.7rem);
    line-height: 1.14;
    font-weight: 800;
    margin: 0 0 12px;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .slide h1 a {
    color: var(--ink);
    transition: color 0.15s ease;
  }
  .slide h1 a:hover {
    color: var(--cat);
  }
  .lead-dek {
    font-family: var(--font);
    font-size: 1.08rem;
    line-height: 1.6;
    color: var(--ink-soft);
    margin: 0 0 12px;
    max-width: 60ch;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .lead-meta {
    display: flex;
    align-items: center;
    gap: 10px;
    font-family: var(--font);
    font-size: 0.85rem;
    color: var(--muted);
  }
  .lead-meta .sep {
    width: 4px;
    height: 4px;
    border-radius: 50%;
    background: var(--cat);
  }
  /* slide indicators */
  .slider-dots {
    display: flex;
    gap: 8px;
    margin-top: 16px;
  }
  .dot {
    width: 30px;
    height: 5px;
    padding: 0;
    border: 0;
    border-radius: 999px;
    background: var(--surface-2);
    cursor: pointer;
    transition: background 0.2s ease, transform 0.2s ease;
  }
  .dot:hover {
    transform: scaleY(1.4);
  }
  .dot.active {
    background: var(--grad);
  }

  /* ===== Headline list (5 latest, with thumbnail + excerpt + read-more) ===== */
  .hlist {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }
  .hitem {
    display: flex;
    gap: 14px;
    align-items: flex-start;
    padding: 16px 0;
    border-bottom: 1px solid var(--line);
    transition: opacity 0.2s ease;
  }
  .hitem:first-child {
    padding-top: 0;
  }
  .hitem:last-child {
    border-bottom: 0;
  }
  .hitem-media {
    flex: none;
    width: 92px;
    aspect-ratio: 1 / 1;
    border-radius: var(--radius-sm);
    overflow: hidden;
    background: var(--surface-2);
    box-shadow: 0 0 0 3px transparent;
    transition: box-shadow 0.2s ease;
  }
  .hitem-media :global(img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.4s ease;
  }
  .hitem:hover .hitem-media :global(img) {
    transform: scale(1.06);
  }
  .hitem.active .hitem-media {
    box-shadow: 0 0 0 3px var(--cat);
  }
  .hitem-body {
    min-width: 0;
    display: flex;
    flex-direction: column;
  }
  .hitem-cat {
    margin-bottom: 4px;
    font-size: 0.7rem;
  }
  .hitem h3 {
    font-size: 1.05rem;
    line-height: 1.3;
    font-weight: 700;
    margin: 0 0 6px;
    color: var(--ink);
    transition: color 0.15s ease;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .hitem:hover h3,
  .hitem.active h3 {
    color: var(--cat);
  }
  .hitem-excerpt {
    font-family: var(--font);
    font-size: 0.85rem;
    line-height: 1.5;
    color: var(--ink-soft);
    margin: 0 0 7px;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .hitem-more {
    font-family: var(--font);
    font-weight: 800;
    font-size: 0.78rem;
    color: var(--cat);
    align-self: flex-start;
  }

  /* ===== Layout: main feed + sidebar ===== */
  .layout {
    display: grid;
    grid-template-columns: 1fr 340px;
    gap: 44px;
    padding-top: 40px;
  }
  .feed {
    min-width: 0;
  }
  .catblock {
    margin-bottom: 42px;
  }
  .blockhead {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    margin-bottom: 24px;
    border-bottom: 2px solid var(--line);
  }
  .blockhead h2 {
    position: relative;
    font-size: clamp(1.4rem, 2.4vw, 1.9rem);
    font-weight: 800;
    margin: 0;
    padding-bottom: 12px;
  }
  .blockhead h2::after {
    content: '';
    position: absolute;
    inset-inline-start: 0;
    bottom: -2px;
    width: 100%;
    height: 3px;
    background: var(--cat);
  }
  .blockmore {
    font-family: var(--font);
    font-weight: 700;
    font-size: 0.9rem;
    color: var(--cat);
    white-space: nowrap;
  }
  .cards2 {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 28px 26px;
  }

  /* ===== Sidebar ===== */
  .sidebar {
    display: flex;
    flex-direction: column;
    gap: 26px;
    min-width: 0;
  }
  .side-card {
    border: 1px solid var(--line);
    border-radius: var(--radius);
    padding: 16px 16px 18px;
    background: var(--paper);
  }
  .side-h {
    font-size: 1.08rem;
    font-weight: 800;
    margin: 0 0 14px;
    padding-bottom: 9px;
    border-bottom: 3px solid var(--accent);
    display: inline-block;
  }
  .picks {
    list-style: none;
    margin: 0;
    padding: 0;
    counter-reset: pick;
  }
  .picks li {
    display: flex;
    gap: 12px;
    padding: 13px 0;
    border-bottom: 1px solid var(--line);
    counter-increment: pick;
  }
  .picks li:first-child {
    padding-top: 0;
  }
  .picks li:last-child {
    border-bottom: 0;
    padding-bottom: 0;
  }
  .picks li::before {
    content: counter(pick);
    flex: none;
    font-family: var(--font-display);
    font-weight: 900;
    font-size: 1.4rem;
    color: var(--cat);
    line-height: 1;
    width: 22px;
  }
  .picks-cat {
    display: block;
    color: var(--cat);
    font-weight: 800;
    font-size: 0.7rem;
    margin-bottom: 4px;
  }
  .picks-title {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 0.98rem;
    line-height: 1.35;
    color: var(--ink);
    transition: color 0.15s ease;
  }
  .picks a:hover .picks-title {
    color: var(--cat);
  }

  /* ===== Sections chips ===== */
  .sections {
    display: flex;
    flex-wrap: wrap;
    gap: 9px;
  }
  .sec-chip {
    display: inline-block;
    font-family: var(--font-display);
    font-weight: 800;
    font-size: 0.9rem;
    padding: 7px 14px;
    border-radius: 999px;
    color: #fff;
    background: var(--cat);
    transition: transform 0.15s ease, filter 0.15s ease;
  }
  .sec-chip:hover {
    transform: translateY(-2px);
    filter: brightness(1.08);
  }
  .newsletter {
    background: var(--surface);
  }
  .newsletter h3 {
    font-size: 1.08rem;
    margin: 0 0 6px;
  }
  .newsletter p {
    font-family: var(--font);
    font-size: 0.9rem;
    color: var(--ink-soft);
    line-height: 1.55;
    margin: 0 0 13px;
  }
  .nl-form {
    display: flex;
    gap: 8px;
  }
  .nl-form input {
    flex: 1;
    min-width: 0;
    padding: 10px 12px;
    border: 1px solid var(--line);
    border-radius: 6px;
    font-family: var(--font);
    font-size: 0.92rem;
  }
  .nl-form button {
    background: var(--accent);
    color: #fff;
    border: 0;
    border-radius: 6px;
    padding: 0 16px;
    font-weight: 800;
    cursor: pointer;
    white-space: nowrap;
  }

  @media (max-width: 980px) {
    .hero {
      grid-template-columns: 1fr;
      gap: 30px;
    }
    .layout {
      grid-template-columns: 1fr;
      gap: 34px;
    }
  }
  @media (max-width: 560px) {
    .cards2 {
      grid-template-columns: 1fr;
    }
    .hitem-media {
      width: 76px;
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .slide {
      transition: none;
    }
  }
</style>

<script>
  // כתבת השער — סליידר שמתחלף כל 2 שניות בין 5 הכתבות האחרונות
  const slider = document.querySelector('[data-slider]');
  if (slider) {
    const slides = Array.from(slider.querySelectorAll('.slide'));
    const dots = Array.from(slider.querySelectorAll('[data-dot]'));
    const hitems = Array.from(document.querySelectorAll('[data-hitem]'));
    const n = slides.length;
    let idx = 0;
    let timer: ReturnType<typeof setInterval> | undefined;

    const show = (next: number) => {
      idx = (next + n) % n;
      slides.forEach((s, i) => s.classList.toggle('active', i === idx));
      dots.forEach((d, i) => d.classList.toggle('active', i === idx));
      hitems.forEach((h, i) => h.classList.toggle('active', i === idx));
    };
    const stop = () => {
      if (timer) clearInterval(timer);
      timer = undefined;
    };
    const start = () => {
      stop();
      if (n > 1) timer = setInterval(() => show(idx + 1), 2000);
    };

    // ניווט ידני בנקודות
    dots.forEach((d, i) =>
      d.addEventListener('click', (e) => {
        e.preventDefault();
        show(i);
        start();
      })
    );
    // מעבר עכבר על כותרת בצד → מציג את הכתבה המתאימה ומשהה
    hitems.forEach((h, i) => {
      h.addEventListener('mouseenter', () => {
        show(i);
        stop();
      });
      h.addEventListener('mouseleave', start);
    });
    // השהיה בעת מעבר עכבר על הסליידר
    slider.addEventListener('mouseenter', stop);
    slider.addEventListener('mouseleave', start);

    show(0);
    start();
  }
</script>
