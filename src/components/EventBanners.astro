---
import data from '../data/events.json';
import { catColor } from '../consts';

// Build-time guard: only show events whose date hasn't passed, soonest first.
const today = new Date().toISOString().slice(0, 10);
const events = (data.events || [])
  .filter((e) => e && e.date && e.date >= today)
  .sort((a, b) => a.date.localeCompare(b.date));

// Split across the two side banners (right gets even indexes, left odd).
const right = events.filter((_, i) => i % 2 === 0).slice(0, 4);
const left = events.filter((_, i) => i % 2 === 1).slice(0, 4);

const fmt = (d) => {
  const [, m, day] = d.split('-');
  return `${parseInt(day, 10)}.${parseInt(m, 10)}`;
};

const columns = [
  { side: 'right', items: right },
  { side: 'left', items: left },
];
---

{
  events.length > 0 &&
    columns.map(
      (col) =>
        col.items.length > 0 && (
          <aside class={`evb evb--${col.side}`} aria-label="אירועים קרובים">
            <div class="evb-inner">
              <div class="evb-head">
                <span class="evb-kicker">xtra</span>
                <span class="evb-title"><span class="evb-live"><span class="evb-dot" />LIVE</span>אירועים קרובים</span>
              </div>
              <div class="evb-list">
                {col.items.map((e) => (
                  <a
                    class="evb-card"
                    href={e.url || '#'}
                    target="_blank"
                    rel="noopener noreferrer"
                    style={`--cat:${catColor(e.category)}`}
                  >
                    <span class="evb-date">{fmt(e.date)}</span>
                    <span class="evb-cat">{e.category}</span>
                    <span class="evb-name">{e.title}</span>
                    {(e.venue || e.city) && (
                      <span class="evb-venue">
                        {[e.venue, e.city].filter(Boolean).join(', ')}
                      </span>
                    )}
                  </a>
                ))}
              </div>
            </div>
          </aside>
        )
    )
}

<style>
  .evb {
    position: fixed;
    top: 250px; /* fallback; JS keeps it just below the header/nav */
    width: 182px;
    max-height: calc(100vh - 280px);
    z-index: 40;
    display: none; /* shown only when there's room beside the 1280px content */
    /* colorful flowing gradient frame that wraps the events */
    padding: 3px;
    background-image: linear-gradient(
      110deg,
      #e6197f,
      #f5921e,
      #8a2be2,
      #12b5c9,
      #6d28d9,
      #e6197f
    );
    background-size: 260% 260%;
    animation: evb-flow 9s ease-in-out infinite;
    border-radius: 18px;
    box-shadow: var(--shadow-lg);
  }
  @keyframes evb-flow {
    0% {
      background-position: 0% 50%;
    }
    50% {
      background-position: 100% 50%;
    }
    100% {
      background-position: 0% 50%;
    }
  }
  .evb--right {
    right: 20px;
  }
  .evb--left {
    left: 20px;
  }

  .evb-inner {
    background: var(--paper);
    border-radius: 15px;
    overflow: hidden;
    max-height: inherit;
    display: flex;
    flex-direction: column;
  }

  /* colorful flowing header ribbon */
  .evb-head {
    background-image: linear-gradient(
      110deg,
      #e6197f,
      #f5921e,
      #8a2be2,
      #12b5c9,
      #6d28d9,
      #e6197f
    );
    background-size: 260% 260%;
    animation: evb-flow 9s ease-in-out infinite;
    padding: 13px 14px 12px;
    text-align: center;
    color: #fff;
  }
  /* live pulse indicator */
  .evb-live {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    vertical-align: middle;
    margin-inline-end: 8px;
    padding: 2px 8px 2px 6px;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.22);
    font-family: var(--font-display);
    font-weight: 900;
    font-size: 0.6rem;
    letter-spacing: 0.1em;
  }
  .evb-dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: #fff;
    animation: evb-pulse 1.3s ease-in-out infinite;
  }
  @keyframes evb-pulse {
    0%,
    100% {
      opacity: 1;
      transform: scale(1);
      box-shadow: 0 0 0 0 rgba(255, 255, 255, 0.7);
    }
    50% {
      opacity: 0.5;
      transform: scale(0.65);
      box-shadow: 0 0 0 5px rgba(255, 255, 255, 0);
    }
  }
  .evb-kicker {
    display: block;
    font-family: var(--font-display);
    font-weight: 900;
    font-size: 0.7rem;
    letter-spacing: 0.22em;
    opacity: 0.92;
    text-transform: uppercase;
  }
  .evb-title {
    display: block;
    font-family: var(--font-display);
    font-weight: 900;
    font-size: 1.02rem;
    line-height: 1.1;
    margin-top: 2px;
    text-shadow: 0 1px 2px rgba(0, 0, 0, 0.15);
  }

  .evb-list {
    display: flex;
    flex-direction: column;
    gap: 10px;
    padding: 12px;
    overflow-y: auto;
    scrollbar-width: thin;
  }
  .evb-card {
    position: relative;
    display: block;
    padding: 11px 12px;
    border: 1px solid var(--line);
    border-radius: var(--radius);
    background: var(--paper);
    border-inline-start: 4px solid var(--cat);
    transition: transform 0.4s ease, box-shadow 0.4s ease, border-color 0.4s ease;
  }
  .evb-card:hover {
    transform: translateY(-2px);
    box-shadow: var(--shadow);
  }
  /* the card currently "live" in the auto-cycle */
  .evb-card.is-live {
    transform: translateY(-3px) scale(1.025);
    box-shadow: 0 10px 26px color-mix(in srgb, var(--cat) 32%, transparent);
    border-color: var(--cat);
  }
  .evb-card.is-live .evb-date {
    animation: evb-chip 1.3s ease-in-out infinite;
  }
  @keyframes evb-chip {
    0%, 100% { transform: scale(1); }
    50% { transform: scale(1.08); }
  }
  .evb-date {
    display: inline-block;
    font-family: var(--font-display);
    font-weight: 900;
    font-size: 0.8rem;
    color: #fff;
    background: var(--cat);
    padding: 2px 9px;
    border-radius: 999px;
    margin-bottom: 8px;
  }
  .evb-cat {
    display: block;
    font-weight: 800;
    font-size: 0.66rem;
    letter-spacing: 0.04em;
    color: var(--cat);
    margin-bottom: 3px;
  }
  .evb-name {
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 0.9rem;
    line-height: 1.28;
    color: var(--ink);
    margin-bottom: 5px;
  }
  .evb-venue {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    font-family: var(--font);
    font-size: 0.75rem;
    line-height: 1.4;
    color: var(--muted);
  }

  /* Only render the rails when the viewport is wide enough to not overlap content */
  @media (min-width: 1600px) {
    .evb {
      display: block;
    }
  }

  /* respect users who prefer no motion */
  @media (prefers-reduced-motion: reduce) {
    .evb,
    .evb-head,
    .evb-dot,
    .evb-card.is-live .evb-date {
      animation: none !important;
    }
    .evb-card.is-live {
      transform: none;
    }
  }
</style>

<script>
  // Keep the floating banners just below the header/sticky-nav so they never
  // overlap it — follows the nav as it becomes sticky on scroll.
  const banners = Array.from(document.querySelectorAll<HTMLElement>('.evb'));
  const nav = document.querySelector<HTMLElement>('.mainnav');
  if (banners.length && nav) {
    const gap = 18;
    const place = () => {
      const top = Math.max(nav.getBoundingClientRect().bottom + gap, gap);
      const maxH = window.innerHeight - top - 20;
      for (const b of banners) {
        b.style.top = `${top}px`;
        b.style.maxHeight = `${maxH}px`;
      }
    };
    place();
    window.addEventListener('scroll', place, { passive: true });
    window.addEventListener('resize', place);
  }

  // Auto-cycle a "live" highlight through each banner's event cards (pauses on hover).
  const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  if (!reduce) {
    for (const b of banners) {
      const cards = Array.from(b.querySelectorAll<HTMLElement>('.evb-card'));
      if (cards.length < 2) continue;
      let k = 0;
      let paused = false;
      b.addEventListener('mouseenter', () => (paused = true));
      b.addEventListener('mouseleave', () => (paused = false));
      const tick = () => {
        if (!paused) {
          cards.forEach((c, i) => c.classList.toggle('is-live', i === k));
          k = (k + 1) % cards.length;
        }
      };
      tick();
      setInterval(tick, 2000);
    }
  }
</script>
