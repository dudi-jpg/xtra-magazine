---
import data from '../data/events.json';
import { catColor } from '../consts';

// Build-time guard: only show events whose date hasn't passed, soonest first.
const today = new Date().toISOString().slice(0, 10);
const events = (data.events || [])
  .filter((e) => e && e.date && e.date >= today)
  .sort((a, b) => a.date.localeCompare(b.date));

// Split across the two side banners (right gets even indexes, left odd).
const right = events.filter((_, i) => i % 2 === 0).slice(0, 4);
const left = events.filter((_, i) => i % 2 === 1).slice(0, 4);

const fmt = (d) => {
  const [, m, day] = d.split('-');
  return `${parseInt(day, 10)}.${parseInt(m, 10)}`;
};

const columns = [
  { side: 'right', items: right },
  { side: 'left', items: left },
];
---

{
  events.length > 0 &&
    columns.map(
      (col) =>
        col.items.length > 0 && (
          <aside class={`evb evb--${col.side}`} aria-label="אירועים קרובים">
            <div class="evb-inner">
              <div class="evb-head">
                <span class="evb-kicker">xtra</span>
                <span class="evb-title">אירועים קרובים</span>
              </div>
              <div class="evb-list">
                {col.items.map((e) => (
                  <a
                    class="evb-card"
                    href={e.url || '#'}
                    target="_blank"
                    rel="noopener noreferrer"
                    style={`--cat:${catColor(e.category)}`}
                  >
                    <span class="evb-date">{fmt(e.date)}</span>
                    <span class="evb-cat">{e.category}</span>
                    <span class="evb-name">{e.title}</span>
                    {(e.venue || e.city) && (
                      <span class="evb-venue">
                        {[e.venue, e.city].filter(Boolean).join(', ')}
                      </span>
                    )}
                  </a>
                ))}
              </div>
            </div>
          </aside>
        )
    )
}

<style>
  .evb {
    position: fixed;
    top: 250px; /* fallback; JS keeps it just below the header/nav */
    width: 182px;
    max-height: calc(100vh - 280px);
    z-index: 40;
    display: none; /* shown only when there's room beside the 1280px content */
    /* colorful gradient frame that wraps the events */
    padding: 3px;
    background: var(--grad);
    border-radius: 18px;
    box-shadow: var(--shadow-lg);
  }
  .evb--right {
    right: 20px;
  }
  .evb--left {
    left: 20px;
  }

  .evb-inner {
    background: var(--paper);
    border-radius: 15px;
    overflow: hidden;
    max-height: inherit;
    display: flex;
    flex-direction: column;
  }

  /* colorful header ribbon */
  .evb-head {
    background: var(--grad);
    padding: 13px 14px 12px;
    text-align: center;
    color: #fff;
  }
  .evb-kicker {
    display: block;
    font-family: var(--font-display);
    font-weight: 900;
    font-size: 0.7rem;
    letter-spacing: 0.22em;
    opacity: 0.92;
    text-transform: uppercase;
  }
  .evb-title {
    display: block;
    font-family: var(--font-display);
    font-weight: 900;
    font-size: 1.02rem;
    line-height: 1.1;
    margin-top: 2px;
    text-shadow: 0 1px 2px rgba(0, 0, 0, 0.15);
  }

  .evb-list {
    display: flex;
    flex-direction: column;
    gap: 10px;
    padding: 12px;
    overflow-y: auto;
    scrollbar-width: thin;
  }
  .evb-card {
    position: relative;
    display: block;
    padding: 11px 12px;
    border: 1px solid var(--line);
    border-radius: var(--radius);
    background: var(--paper);
    border-inline-start: 4px solid var(--cat);
    transition: transform 0.15s ease, box-shadow 0.15s ease;
  }
  .evb-card:hover {
    transform: translateY(-2px);
    box-shadow: var(--shadow);
  }
  .evb-date {
    display: inline-block;
    font-family: var(--font-display);
    font-weight: 900;
    font-size: 0.8rem;
    color: #fff;
    background: var(--cat);
    padding: 2px 9px;
    border-radius: 999px;
    margin-bottom: 8px;
  }
  .evb-cat {
    display: block;
    font-weight: 800;
    font-size: 0.66rem;
    letter-spacing: 0.04em;
    color: var(--cat);
    margin-bottom: 3px;
  }
  .evb-name {
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 0.9rem;
    line-height: 1.28;
    color: var(--ink);
    margin-bottom: 5px;
  }
  .evb-venue {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    font-family: var(--font);
    font-size: 0.75rem;
    line-height: 1.4;
    color: var(--muted);
  }

  /* Only render the rails when the viewport is wide enough to not overlap content */
  @media (min-width: 1600px) {
    .evb {
      display: block;
    }
  }
</style>

<script>
  // Keep the floating banners just below the header/sticky-nav so they never
  // overlap it — follows the nav as it becomes sticky on scroll.
  const banners = Array.from(document.querySelectorAll<HTMLElement>('.evb'));
  const nav = document.querySelector<HTMLElement>('.mainnav');
  if (banners.length && nav) {
    const gap = 18;
    const place = () => {
      const top = Math.max(nav.getBoundingClientRect().bottom + gap, gap);
      const maxH = window.innerHeight - top - 20;
      for (const b of banners) {
        b.style.top = `${top}px`;
        b.style.maxHeight = `${maxH}px`;
      }
    };
    place();
    window.addEventListener('scroll', place, { passive: true });
    window.addEventListener('resize', place);
  }
</script>
