---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import FormattedDate from './FormattedDate.astro';
import { catColor } from '../consts';

interface Props {
  article: CollectionEntry<'articles'>;
}

const { article } = Astro.props;
const { title, description, category, author, pubDate, cover, coverAlt } = article.data;
const href = `/articles/${article.id}/`;
const catHref = `/category/${encodeURIComponent(category)}/`;
---

<article class="card" style={`--cat:${catColor(category)}`}>
  <a href={href} class="card-media" tabindex="-1" aria-hidden="true">
    {
      cover ? (
        <Image src={cover} alt={coverAlt} widths={[400, 800]} sizes="(max-width: 700px) 100vw, 400px" />
      ) : (
        <div class="card-fallback">xtra</div>
      )
    }
  </a>
  <div class="card-body">
    <a href={catHref} class="card-cat">{category}</a>
    <h3><a href={href}>{title}</a></h3>
    <p class="card-dek">{description}</p>
    <div class="card-meta">
      <span>{author}</span>
      <span class="sep"></span>
      <FormattedDate date={pubDate} />
    </div>
  </div>
</article>

<style>
  .card {
    display: flex;
    flex-direction: column;
  }
  .card-media {
    display: block;
    aspect-ratio: 16 / 10;
    overflow: hidden;
    background: var(--surface-2);
    border-radius: var(--radius-sm);
  }
  .card-media :global(img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.45s ease;
  }
  .card:hover .card-media :global(img) {
    transform: scale(1.05);
  }
  .card-fallback {
    display: grid;
    place-items: center;
    height: 100%;
    font-family: var(--font);
    font-weight: 800;
    font-size: 1.6rem;
    letter-spacing: 0.06em;
    color: #fff;
    background: linear-gradient(135deg, var(--cat), var(--navy));
  }

  .card-body {
    padding-top: 14px;
  }
  .card-cat {
    display: inline-block;
    font-family: var(--font);
    font-weight: 800;
    font-size: 0.72rem;
    letter-spacing: 0.04em;
    color: var(--cat);
    margin-bottom: 8px;
  }
  .card-cat:hover {
    text-decoration: underline;
  }
  .card h3 {
    font-size: 1.32rem;
    line-height: 1.28;
    font-weight: 700;
    margin: 0 0 9px;
  }
  .card h3 a {
    color: var(--ink);
    transition: color 0.15s ease;
  }
  .card h3 a:hover {
    color: var(--cat);
  }
  .card-dek {
    font-family: var(--font);
    font-size: 0.95rem;
    line-height: 1.6;
    color: var(--ink-soft);
    margin: 0 0 12px;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .card-meta {
    display: flex;
    align-items: center;
    gap: 9px;
    font-family: var(--font);
    font-size: 0.82rem;
    color: var(--muted);
  }
  .card-meta .sep {
    width: 3px;
    height: 3px;
    border-radius: 50%;
    background: var(--cat);
  }
</style>
