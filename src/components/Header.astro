---
import { CATEGORIES } from '../consts';
import Logo from './Logo.astro';

const catHref = (c: string) => `/category/${encodeURIComponent(c)}/`;
const today = new Intl.DateTimeFormat('he-IL', {
  weekday: 'long',
  day: 'numeric',
  month: 'long',
  year: 'numeric',
}).format(new Date());
---

<header class="site-header">
  <!-- Top utility bar -->
  <div class="topbar">
    <div class="container topbar-in">
      <span class="date">{today}</span>
      <span class="tlinks">
        <a href="/archive/">כל הכתבות</a>
        <a href="/rss.xml">RSS</a>
        <a href="/about/">אודות</a>
      </span>
    </div>
  </div>

  <!-- Masthead: centered logo -->
  <div class="masthead">
    <a href="/" class="logo-link" aria-label="xtra — עמוד הבית">
      <Logo size={288} />
    </a>
  </div>

  <!-- Sticky nav bar -->
  <nav class="mainnav" aria-label="ניווט ראשי">
    <div class="container nav-in">
      <button class="menu-toggle" id="menuToggle" aria-label="תפריט">
        <span></span><span></span><span></span>
      </button>
      <div class="nav-links" id="navLinks">
        <a href="/">ראשי</a>
        {CATEGORIES.map((c) => <a href={catHref(c)}>{c}</a>)}
      </div>
    </div>
  </nav>
</header>

<style>
  .site-header {
    background: var(--paper);
  }
  .topbar {
    background: var(--navy);
    color: rgba(255, 255, 255, 0.7);
    font-size: 0.78rem;
  }
  .topbar-in {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 36px;
  }
  .topbar .date {
    color: rgba(255, 255, 255, 0.6);
  }
  .tlinks {
    display: flex;
    gap: 18px;
  }
  .tlinks a {
    color: rgba(255, 255, 255, 0.78);
    transition: color 0.15s ease;
  }
  .tlinks a:hover {
    color: var(--accent);
  }

  .masthead {
    display: flex;
    justify-content: center;
    padding: 22px 20px 18px;
  }

  .mainnav {
    position: sticky;
    top: 0;
    z-index: 50;
    background: var(--paper);
    border-top: 1px solid var(--line);
    border-bottom: 3px solid transparent;
    border-image: var(--grad) 1;
  }
  .nav-in {
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 50px;
  }
  .nav-links {
    display: flex;
    align-items: center;
    gap: 30px;
    font-weight: 700;
    font-size: 1rem;
  }
  .nav-links a {
    position: relative;
    padding: 14px 0;
    color: var(--ink);
    transition: color 0.15s ease;
  }
  .nav-links a:hover {
    color: var(--accent);
  }
  .nav-links a::after {
    content: '';
    position: absolute;
    inset-inline: 0;
    bottom: -3px;
    height: 3px;
    background: var(--accent);
    transform: scaleX(0);
    transition: transform 0.18s ease;
  }
  .nav-links a:hover::after {
    transform: scaleX(1);
  }

  .menu-toggle {
    display: none;
    position: absolute;
    inset-inline-start: 20px;
    flex-direction: column;
    gap: 5px;
    background: none;
    border: 0;
    cursor: pointer;
    padding: 8px;
  }
  .menu-toggle span {
    width: 24px;
    height: 2px;
    background: var(--ink);
    border-radius: 2px;
  }

  @media (max-width: 820px) {
    /* scale the enlarged logo down on small screens so it doesn't overflow */
    .logo-link {
      display: inline-block;
      transform: scale(0.55);
      transform-origin: center;
    }
    .topbar .date {
      display: none;
    }
    .topbar-in {
      justify-content: center;
    }
    .nav-in {
      justify-content: flex-start;
    }
    .menu-toggle {
      display: flex;
    }
    .nav-links {
      display: none;
      position: absolute;
      top: 100%;
      inset-inline: 0;
      flex-direction: column;
      gap: 0;
      background: var(--paper);
      border-bottom: 1px solid var(--line);
      padding: 6px 20px 14px;
    }
    .nav-links.open {
      display: flex;
    }
    .nav-links a {
      padding: 12px 0;
      border-bottom: 1px solid var(--line);
    }
  }
</style>

<script>
  const t = document.getElementById('menuToggle');
  const n = document.getElementById('navLinks');
  t?.addEventListener('click', () => n?.classList.toggle('open'));
</script>
